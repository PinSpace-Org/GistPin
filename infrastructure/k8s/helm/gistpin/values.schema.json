{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GistPin Helm Values",
  "description": "JSON Schema validation for GistPin Helm chart values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "global",
    "backend",
    "analytics",
    "ingress",
    "postgresql",
    "serviceAccount"
  ],
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "object" },
          "default": []
        },
        "nameOverride": { "type": "string" },
        "fullnameOverride": { "type": "string" }
      }
    },
    "backend": {
      "type": "object",
      "required": ["image", "service", "resources"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:[._-/][a-z0-9]+)*$"
            },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 2
        },
        "service": {
          "type": "object",
          "required": ["type", "port", "targetPort"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
            },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
                "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ki)$" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
                "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ki)$" }
              }
            }
          }
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 0, "maximum": 100 },
            "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "existingSecret": { "type": "string" },
        "secrets": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "extraEnv": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "analytics": {
      "type": "object",
      "required": ["image", "service", "resources"],
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 1
        },
        "service": {
          "type": "object",
          "required": ["type", "port", "targetPort"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
            },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
                "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ki)$" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
                "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ki)$" }
              }
            }
          }
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string", "format": "hostname" },
              "serviceName": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretName": { "type": "string" },
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string" },
            "username": { "type": "string" },
            "existingSecret": { "type": "string" },
            "password": { "type": "string" },
            "postgresPassword": { "type": "string" }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "initdb": { "type": "object" },
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string", "pattern": "^[0-9]+(Gi|Ti|Mi)$" },
                "storageClass": { "type": "string" }
              }
            },
            "resources": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "properties": {
                    "cpu": { "type": "string" },
                    "memory": { "type": "string" }
                  }
                },
                "limits": {
                  "type": "object",
                  "properties": {
                    "cpu": { "type": "string" },
                    "memory": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "password": { "type": "string" }
          }
        },
        "architecture": {
          "type": "string",
          "enum": ["standalone", "replication"]
        },
        "master": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false }
      }
    },
    "env": {
      "type": "string",
      "description": "Deployment environment label",
      "enum": ["dev", "staging", "production"]
    }
  }
}
